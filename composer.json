{
    "name": "bengal-studio/ai-sdk-openai",
    "description": "OpenAI provider for AI SDK PHP — Chat, Completion, Responses, and Embedding models.",
    "type": "library",
    "license": "MIT",
    "keywords": ["ai", "openai", "gpt", "chatgpt", "embeddings", "language-model", "ai-sdk"],
    "authors": [
        {
            "name": "Bengal Studio",
            "homepage": "https://github.com/bengal-studio"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../ai-sdk-php"
        }
    ],
    "require": {
        "php": "^8.1",
        "bengal-studio/ai-sdk": "dev-main",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "BengalStudio\\AI\\OpenAI\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "BengalStudio\\AI\\OpenAI\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
